<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:barcode="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="ScannerApp.MainPage"
             Title="Scanner"
             AutomationId="ScannerPage">

    <AbsoluteLayout>
        <barcode:CameraView
            x:Name="Camera"
            AutomationId="ScannerCameraView"
            AbsoluteLayout.LayoutFlags="All"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            OnDetectionFinished="OnDetectionFinished"
            CaptureQuality="High"
            ForceInverted="True"
            TapToFocusEnabled="True"
            BarcodeSymbologies="All"
            AimMode="True" />

        <GraphicsView
            x:Name="Graphics"
            AbsoluteLayout.LayoutFlags="All"
            AbsoluteLayout.LayoutBounds="0,0,1,1"
            InputTransparent="True" />

        <!-- Center aiming dot overlay -->
        <Border
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="14"
            HeightRequest="14"
            Stroke="White"
            StrokeThickness="2"
            BackgroundColor="#66000000"
            StrokeShape="RoundRectangle 999"
            InputTransparent="True"
            AbsoluteLayout.LayoutFlags="PositionProportional"
            AbsoluteLayout.LayoutBounds="0.5,0.5,14,14" />

        <Grid
            ColumnDefinitions="*,*,*,*,*,*"
            AbsoluteLayout.LayoutFlags="All"
            AbsoluteLayout.LayoutBounds="0,0,1,0.12"
            Padding="10"
            BackgroundColor="#66000000">

            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Text="←"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="BackButton_Clicked" />

            <Button
                Grid.Column="1"
                Text="C"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="CameraButton_Clicked" />

            <Button
                Grid.Column="2"
                Text="T"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="TorchButton_Clicked" />

            <Picker
                x:Name="Quality"
                Grid.Column="3"
                BackgroundColor="Transparent"
                Title="Q"
                WidthRequest="60"
                HeightRequest="50"
                SelectedIndexChanged="Quality_SelectedIndexChanged" />

            <Button
                Grid.Column="4"
                Text="V"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="VibrateButton_Clicked" />

            <Button
                Grid.Column="5"
                Text="P"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="PauseButton_Clicked" />
        </Grid>

        <VerticalStackLayout
            Padding="16"
            Spacing="8"
            BackgroundColor="#80000000"
            AbsoluteLayout.LayoutFlags="All"
            AbsoluteLayout.LayoutBounds="0,1,1,0.18">
            <Label
                x:Name="ResultLabel"
                AutomationId="ScannerResultLabel"
                Text="Point the camera at a barcode or QR code."
                TextColor="White"
                LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </AbsoluteLayout>

</ContentPage>
