<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:barcode="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="ScannerApp.MainPage"
             Title="Scanner"
             AutomationId="ScannerPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <barcode:CameraView
                x:Name="Camera"
                AutomationId="ScannerCameraView"
                OnDetectionFinished="OnDetectionFinished"
                CaptureQuality="High"
                ForceInverted="True"
                TapToFocusEnabled="True"
                BarcodeSymbologies="All"
                AimMode="True" />

            <GraphicsView
                x:Name="Graphics"
                InputTransparent="True" />

            <Border
                HorizontalOptions="Center"
                VerticalOptions="Center"
                WidthRequest="14"
                HeightRequest="14"
                Stroke="White"
                StrokeThickness="2"
                BackgroundColor="#66000000"
                StrokeShape="RoundRectangle 999"
                InputTransparent="True" />
        </Grid>

        <Grid
            Grid.Row="1"
            ColumnDefinitions="*,*,*,*,*,*"
            Padding="10"
            BackgroundColor="#66000000">

            <Button
                x:Name="BackButton"
                Grid.Column="0"
                Text="←"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="BackButton_Clicked" />

            <Button
                Grid.Column="1"
                Text="C"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="CameraButton_Clicked" />

            <Button
                Grid.Column="2"
                Text="T"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="TorchButton_Clicked" />

            <Picker
                x:Name="Quality"
                Grid.Column="3"
                BackgroundColor="Transparent"
                Title="Q"
                WidthRequest="60"
                HeightRequest="50"
                SelectedIndexChanged="Quality_SelectedIndexChanged" />

            <Button
                Grid.Column="4"
                Text="V"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="VibrateButton_Clicked" />

            <Button
                Grid.Column="5"
                Text="P"
                WidthRequest="50"
                HeightRequest="50"
                CornerRadius="25"
                Clicked="PauseButton_Clicked" />
        </Grid>

        <Frame Grid.Row="2" BackgroundColor="#80000000" Padding="12" Margin="10" CornerRadius="12">
            <Label
                x:Name="ResultLabel"
                AutomationId="ScannerResultLabel"
                Text="Point the camera at a barcode or QR code."
                TextColor="White"
                LineBreakMode="WordWrap" />
        </Frame>
    </Grid>

</ContentPage>
