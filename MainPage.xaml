<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:barcode="clr-namespace:BarcodeScanning;assembly=BarcodeScanning.Native.Maui"
             x:Class="ScannerApp.MainPage"
             Title="Scanner"
             AutomationId="ScannerPage">

    <Grid>
        <barcode:CameraView
            x:Name="Camera"
            AutomationId="ScannerCameraView"
            OnDetectionFinished="OnDetectionFinished"
            HorizontalOptions="Fill"
            VerticalOptions="Fill" />

        <!-- Center aiming dot overlay -->
        <Border
            HorizontalOptions="Center"
            VerticalOptions="Center"
            WidthRequest="14"
            HeightRequest="14"
            Stroke="White"
            StrokeThickness="2"
            BackgroundColor="#66000000"
            StrokeShape="RoundRectangle 999"
            InputTransparent="True" />

        <VerticalStackLayout
            Padding="16"
            VerticalOptions="End"
            Spacing="8"
            BackgroundColor="#80000000">
            <Label
                x:Name="ResultLabel"
                AutomationId="ScannerResultLabel"
                Text="Point the camera at a barcode or QR code."
                TextColor="White"
                LineBreakMode="WordWrap" />
        </VerticalStackLayout>
    </Grid>

</ContentPage>
